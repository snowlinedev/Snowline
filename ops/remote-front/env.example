# Snowline remote front — environment. In deploy the SECRETS (owner password,
# signing key, tailscale auth key) are `fly secrets set`, NOT committed; the
# non-secret URLs live in fly.toml's [env]. This file documents every knob for
# local runs (`uv run snowline-remote-front`) and as a reference.

# --- Required -----------------------------------------------------------------
# Public issuer / connector base URL (fly-terminated TLS in deploy).
REMOTE_FRONT_ISSUER_URL=https://snowline-remote-front-CHANGEME.fly.dev
# Upstream gateway surface over the tailnet (dedicated surface, not `main`).
REMOTE_FRONT_UPSTREAM=http://MINI-HOSTNAME.CHANGEME.ts.net:8850/remote/mcp
# The single fixed resource-owner credential checked at /login (a fly SECRET).
REMOTE_FRONT_OWNER_PASSWORD=change-me-to-a-long-random-passphrase

# --- Recommended (fly secret) -------------------------------------------------
# HMAC key that signs access tokens. Unset → an ephemeral per-process key is
# generated (access tokens die on restart; clients recover via refresh token).
REMOTE_FRONT_SIGNING_KEY=change-me-to-a-32+-byte-random-secret

# --- Optional -----------------------------------------------------------------
# REMOTE_FRONT_RESOURCE_URL defaults to ISSUER_URL + /mcp.
# REMOTE_FRONT_RESOURCE_URL=https://snowline-remote-front-CHANGEME.fly.dev/mcp
# SQLite store path (persist clients + refresh tokens). Unset → in-memory.
REMOTE_FRONT_STORE_PATH=/data/remote-front.db
# Access-token TTL seconds (default 900 = 15 min).
# REMOTE_FRONT_ACCESS_TTL=900
# Refresh-token TTL seconds (default 2592000 = 30 days).
# REMOTE_FRONT_REFRESH_TTL=2592000
# Upstream CONNECT timeout seconds (default 10; the READ is unbounded for SSE).
# REMOTE_FRONT_UPSTREAM_CONNECT_TIMEOUT=10
# Resource-owner subject id stamped on tokens (default "owner").
# REMOTE_FRONT_SUBJECT=owner
# Bind host/port (deploy defaults 0.0.0.0:8080).
# REMOTE_FRONT_HOST=0.0.0.0
# REMOTE_FRONT_PORT=8080

# --- tailscaled sidecar (deploy only; consumed by start.sh, not the app) ------
# Auth key for a TAGGED node (tag:remote-front) — a fly SECRET. See the ACL
# stanza in docs/ops/remote-front-runbook.md.
# TAILSCALE_AUTHKEY=tskey-auth-CHANGEME
