# primary — the always-on hub on the Mac mini (replication-continuity §2.1/§5.1).
# The hub uses the SAME loopback-first posture as the spoke (it keeps mini-local
# sessions alive through a tailnet outage — the vacation scenario, §5.1) and the
# SAME full trusted-CIDR list. The differences from env.roam.example are the
# instance id, the source ids, and Layer-0 standing posture (§2.1).

# --- identity ---------------------------------------------------------------
export SNOWLINE_INSTANCE_ID=primary

# --- the full trusted set (§5.1 — state it IN FULL; it REPLACES the default) --
export SNOWLINE_TRUSTED_CIDRS="100.64.0.0/10,127.0.0.0/8,::1"

# --- platform --------------------------------------------------------------
export SNOWLINE_PLATFORM_DATABASE_URL="postgresql+psycopg:///snowline_platform"
export SNOWLINE_PLATFORM_HOST=127.0.0.1        # loopback ONLY (§5.1)
export SNOWLINE_PLATFORM_PORT=8848
export SNOWLINE_REPLICATION_SOURCE_ID=primary.platform
export SNOWLINE_REPLICATION_INTERVAL=30

# --- governance / memory (each its own process + source id) -----------------
export SNOWLINE_GOVERNANCE_DATABASE_URL="postgresql+psycopg:///snowline_governance"
export SNOWLINE_GOVERNANCE_BASE_URL="http://127.0.0.1:8801"
export SNOWLINE_MEMORY_DATABASE_URL="postgresql+psycopg:///snowline_memory"
export SNOWLINE_MEMORY_BASE_URL="http://127.0.0.1:8802"
export SNOWLINE_PLATFORM_URL="http://127.0.0.1:8848"
# governance process: SNOWLINE_REPLICATION_SOURCE_ID=primary.governance
# memory process:     SNOWLINE_REPLICATION_SOURCE_ID=primary.memory

# --- Layer 0 standing posture (§2.1 — the hub must actually be always-on) ----
# These are NOT set by this file; they are host configuration recorded here as a
# checklist (see the runbook §"Primary standing posture"):
#   - sudo pmset -a sleep 0 disablesleep 1        (never sleep)
#   - tailscaled as a SYSTEM daemon, not the menu-bar app
#   - auto-restart after power loss (pmset autorestart 1)
#   - external dead-man's switch: a cron pinging a hosted healthcheck so a
#     silent disconnect pages you instead of waiting to be discovered.
