# roam — the roaming spoke (replication-continuity §5/§5.1). Copy to a private
# location, fill the tailnet host/IPs, and `set -a; source` it before starting
# each service (or reference it from the launchd plists in ops/roam/launchd/).
#
# THREE things are load-bearing here and cause silent failure if wrong:
#   1. SNOWLINE_TRUSTED_CIDRS is stated IN FULL (it REPLACES the default when
#      set — §5.1 config trap). Behind the tailscale-serve -> loopback front,
#      cross-instance deliveries arrive with a LOOPBACK peer IP, so dropping the
#      loopback entries is the outage. As of issue #93 the platform's own
#      default (config.py DEFAULT_TRUSTED_CIDRS) matches the SDK admin
#      surface's — both are tailnet + loopback when unset — but setting this
#      env explicitly on EVERY process is still recommended for clarity.
#   2. Every service BINDS LOOPBACK ONLY. Never 0.0.0.0 on the laptop (§5.1) —
#      a wildcard bind parks a pre-auth listener on every hotel LAN it joins.
#      The tailnet path is tailscaled's (ops/roam/tailscale-serve.sh).
#   3. SNOWLINE_REPLICATION_SOURCE_ID is instance-qualified <instance>.<plugin>
#      and fail-loud if unset (§3). A defaulted/duplicated source id forks stream
#      identity between the two instances.

# --- identity ---------------------------------------------------------------
export SNOWLINE_INSTANCE_ID=roam

# --- the full trusted set (§5.1 — state it IN FULL; it REPLACES the default) --
# tailnet CGNAT range + IPv4 loopback + IPv6 loopback. Pin the listeners to one
# address family (below) so a dual-stack ::ffff:127.0.0.1 peer can't dodge this.
export SNOWLINE_TRUSTED_CIDRS="100.64.0.0/10,127.0.0.0/8,::1"

# --- platform (the composed surface + scope stream, §8) ---------------------
export SNOWLINE_PLATFORM_DATABASE_URL="postgresql+psycopg:///snowline_platform"
export SNOWLINE_PLATFORM_HOST=127.0.0.1        # loopback ONLY (§5.1)
export SNOWLINE_PLATFORM_PORT=8848
# the platform's OWN replication source id for its scope stream (§8)
export SNOWLINE_REPLICATION_SOURCE_ID=roam.platform
# delivery cadence (§3.1); a two-week partition still retries every ~5 min here
export SNOWLINE_REPLICATION_INTERVAL=30

# --- governance plugin ------------------------------------------------------
export SNOWLINE_GOVERNANCE_DATABASE_URL="postgresql+psycopg:///snowline_governance"
export SNOWLINE_GOVERNANCE_BASE_URL="http://127.0.0.1:8801"   # advertised loopback (§4.1)
export SNOWLINE_PLATFORM_URL="http://127.0.0.1:8848"          # plugins reach the platform on loopback
# NOTE: governance runs as its OWN process with its OWN source id — set this in
# that process's environment (the launchd plist), NOT globally, or it clobbers
# the platform's. governance: SNOWLINE_REPLICATION_SOURCE_ID=roam.governance
# memory:     SNOWLINE_REPLICATION_SOURCE_ID=roam.memory

# --- memory plugin ----------------------------------------------------------
export SNOWLINE_MEMORY_DATABASE_URL="postgresql+psycopg:///snowline_memory"
export SNOWLINE_MEMORY_BASE_URL="http://127.0.0.1:8802"

# --- pairing CLI convenience ------------------------------------------------
# the primary's tailnet address (fill in your mini's 100.x IP or MagicDNS name)
export SNOWLINE_LOCAL_PLATFORM_URL="http://127.0.0.1:8848"
# e.g. PRIMARY=http://mini.tailnet-name.ts.net:8848
